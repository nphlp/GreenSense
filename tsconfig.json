{
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "strictNullChecks": true, // differentiate between null and undefined
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "@atoms/*": ["./components/atoms/*"],
            "@app/*": ["./app/*"],
            "@comps/*": ["./components/*"],
            "@core/*": ["./core/*"],
            "@lib/*": ["./lib/*"],
            "@public/*": ["./public/*"],
            "@utils/*": ["./utils/*"],
            "@/*": ["./*"]
        }
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.mts", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
    "exclude": ["node_modules", ".next", "NextjsDeploy"]
}
