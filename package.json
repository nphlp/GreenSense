{
    "name": "greensense",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "prepare": "husky || true",
        "typegen": "next typegen",
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --check --log-level warn",
        "format:fix": "prettier . --write --log-level error",
        "type": "tsc --noEmit",
        "checks": "bun run type && bun run lint:fix && bun run format:fix"
    },
    "lint-staged": {
        "*.{js,ts,tsx}": [
            "eslint --fix"
        ],
        "*.{js,ts,tsx,json,css,md,yml,yaml}": "prettier --write"
    },
    "dependencies": {
        "next": "16.2.1-canary.5",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@commitlint/types": "^20.5.0",
        "@next/bundle-analyzer": "^16.2.1",
        "@tailwindcss/postcss": "^4.2.2",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "babel-plugin-react-compiler": "^1.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dayjs": "^1.11.20",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "lodash": "^4.17.23",
        "lucide-react": "^0.563.0",
        "postcss": "^8.5.8",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "server-only": "^0.0.1",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "typescript": "^5.9.3",
        "zod": "^4.3.6"
    }
}
